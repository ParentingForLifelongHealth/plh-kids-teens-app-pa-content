{
  "flow_type": "template",
  "flow_name": "onboarding_settings_page_6",
  "status": "released",
  "rows": [
    {
      "name": "facilitator_id",
      "value": "@fields.facilitator_id"
    },
    {
      "name": "facilitator_data",
      "value": "characters.@local.facilitator_id"
    },
    {
      "name": "facilitator_row",
      "value": "@data.@local.facilitator_data"
    },
    {
      "name": "speaker_name",
      "value": "@local.facilitator_row.name"
    },
    {
      "name": "speaker_image_asset",
      "value": "@local.facilitator_row.image_asset"
    },
    {
      "name": "speaker_position",
      "value": "left",
      "exclude_from_translation": true
    },
    {
      "name": "variant",
      "value": "gray",
      "exclude_from_translation": true
    },
    {
      "type": "text_bubble",
      "name": "text_bubble",
      "value": "@global.facilitator_message_user_location",
      "parameter_list": "speaker_image_asset: @local.speaker_image_asset;\nspeaker_name: @local.speaker_name;\nspeaker_position: @local.speaker_position;\nvariant: @local.variant;",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "question_user_location",
      "value": "@global.question_user_location",
      "parameter_list": "style: emphasised;"
    },
    {
      "type": "combo_box",
      "name": "user_location_select",
      "value": "@fields.user_location",
      "parameter_list": "answer_list: @data.user_location;\nplaceholder: @global.placeholder_user_location;\nvariant: dropdown;\nwrap: true;",
      "condition": "!!@fields.user_location",
      "exclude_from_translation": true
    },
    {
      "type": "combo_box",
      "name": "user_location_select",
      "parameter_list": "answer_list: @data.user_location;\nplaceholder: @global.placeholder_user_location;\nvariant: dropdown;\nwrap: true;",
      "condition": "!@fields.user_location",
      "exclude_from_translation": true
    },
    {
      "name": "district_name"
    },
    {
      "type": "data_items",
      "name": "get_district_name",
      "value": "@data.user_location",
      "action_list": "data_changed | set_local : district_name: @items[0]?.text::eng;",
      "parameter_list": "filter:  @item.id == @local.user_location_select;\nlimit: 1;",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "question_user_district_undef",
      "value": "@global.question_user_district_undefined",
      "parameter_list": "style: emphasised;",
      "condition": "!@local.user_location_select"
    },
    {
      "type": "text",
      "name": "question_user_district",
      "value": "@global.question_user_district",
      "parameter_list": "style: emphasised;",
      "condition": "!!@local.user_location_select"
    },
    {
      "type": "begin_combo_box",
      "name": "user_district_select",
      "value": "@fields.user_location_district",
      "parameter_list": "placeholder: @global.placeholder_user_district;\nvariant: dropdown;\nwrap: true;",
      "condition": "!!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "begin_data_items",
      "value": "user_location_district",
      "parameter_list": "filter: @item.province == @local.user_location_select",
      "condition": "!!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "condition": "!!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "end_combo_box",
      "condition": "!!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "begin_combo_box",
      "name": "user_district_select",
      "parameter_list": "placeholder: @global.placeholder_user_district;\nvariant: dropdown;\nwrap: true;\ndisabled: !@local.user_location_select",
      "condition": "!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "begin_data_items",
      "value": "user_location_district",
      "parameter_list": "filter: @item.province == @local.user_location_select",
      "condition": "!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "condition": "!@fields.user_location_district ",
      "exclude_from_translation": true
    },
    {
      "type": "end_combo_box",
      "condition": "!@fields.user_location_district",
      "exclude_from_translation": true
    },
    {
      "name": "completed_enabled",
      "value": "!!@local.user_location_select && !!@local.user_district_select",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.continue",
      "action_list": "click | set_field: user_location: @local.user_location_select;\nclick | set_field: user_location_district: @local.user_district_select;\nclick | emit: completed;",
      "parameter_list": "style: navigation;\ndisabled: !@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}