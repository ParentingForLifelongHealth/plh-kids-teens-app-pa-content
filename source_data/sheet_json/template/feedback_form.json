{
  "flow_type": "template",
  "flow_name": "feedback_form",
  "status": "released",
  "rows": [
    {
      "type": "begin_template",
      "name": "settings_header",
      "value": "settings_header",
      "action_list": "uncompleted | emit: uncompleted; "
    },
    {
      "name": "title",
      "value": "Feedback Form"
    },
    {
      "type": "end_template"
    },
    {
      "type": "text",
      "value": "Your Feedback"
    },
    {
      "name": "feedback_placeholder",
      "value": "Tell us what's on your mind..."
    },
    {
      "type": "text_area",
      "name": "text_feedback",
      "parameter_list": "placeholder: @local.feedback_placeholder"
    },
    {
      "name": "text_feedback_valid",
      "value": "@calc(!!@local.text_feedback)",
      "comment": true
    },
    {
      "type": "text",
      "value": "Where?"
    },
    {
      "name": "where_placeholder",
      "value": "Where?"
    },
    {
      "type": "combo_box",
      "name": "where",
      "parameter_list": "placeholder: @local.where_placeholder;\nanswer_list: @data.where_options;"
    },
    {
      "name": "location_placeholder",
      "value": "Please specify the location"
    },
    {
      "name": "specify_location"
    },
    {
      "type": "text_box",
      "name": "specify_location",
      "parameter_list": "placeholder: @local.location_placeholder",
      "condition": "@local.where == \"other\""
    },
    {
      "name": "where_valid",
      "value": "@calc(!!@local.where)",
      "comment": true
    },
    {
      "name": "valid",
      "value": "@local.text_feedback_valid"
    },
    {
      "name": "toast_message",
      "value": "Thanks! This helps us improve your experience on the app"
    },
    {
      "type": "button",
      "value": "Submit Feedback",
      "action_list": "click | add_data | \n_list_id: feedback_data,\ntext: @local.text_feedback,\nwhere: @local.where,\nspecify_location: @local.specify_location,\ntimestamp: @calc(timestamp());\nclick | emit: completed;\nclick | toast | message: @local.toast_message;",
      "parameter_list": "disabled: !@local.valid;\nstyle: flexible;",
      "style_list": "margin-bottom: 24px;\npadding: 12px 24px"
    }
  ]
}