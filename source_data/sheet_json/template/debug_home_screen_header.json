{
  "flow_type": "template",
  "flow_name": "debug_home_screen_header",
  "status": "released",
  "rows": [
    {
      "name": "countdown_days",
      "value": "@fields.countdown_days"
    },
    {
      "name": "hp_uncompleted_ids"
    },
    {
      "type": "begin_data_items",
      "name": "loop_2",
      "value": "@data.hp_check_in",
      "action_list": "data_changed | set_local : hp_uncompleted_ids : @items.map(item => item.id)",
      "parameter_list": "filter: !@item.unlocked_activity",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items"
    },
    {
      "name": "hp_unlocked_ids"
    },
    {
      "type": "begin_data_items",
      "name": "loop_1",
      "value": "@data.courses",
      "action_list": "data_changed | set_local : hp_unlocked_ids : @items.map(item => item.id)",
      "parameter_list": "filter: !!@item.completed_ts && window.date_fns.differenceInDays(new Date(),new Date(new Date(@item.completed_ts).setHours(0,0,0,0))) >= @local.countdown_days;\nsort: completed_ts;",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "text",
      "name": "debug_1",
      "value": "@local.hp_unlocked_ids",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "debug_2",
      "value": "@local.hp_uncompleted_ids",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "name": "hp_id",
      "value": "@calc((@local.hp_unlocked_ids || []).find(x => (@local.hp_uncompleted_ids || []).includes(x)))",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "debug_3",
      "value": "HP id: @local.hp_id",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "name": "hp_review_template",
      "value": "stack_hp_review_@local.hp_id",
      "exclude_from_translation": true
    },
    {
      "name": "hp_check_in_row",
      "value": "hp_check_in.@local.hp_id",
      "exclude_from_translation": true
    },
    {
      "name": "hp_check_in_data",
      "value": "@data.@local.hp_check_in_row",
      "exclude_from_translation": true
    },
    {
      "name": "hp_check_in_notification_text",
      "value": "@local.hp_check_in_data.notification_text",
      "exclude_from_translation": true
    },
    {
      "type": "begin_template",
      "value": "header_button",
      "condition": "!!@local.hp_id"
    },
    {
      "name": "title",
      "value": "@local.hp_check_in_notification_text",
      "exclude_from_translation": true
    },
    {
      "name": "pop_up",
      "value": true
    },
    {
      "name": "template",
      "value": "@local.hp_review_template",
      "exclude_from_translation": true
    },
    {
      "name": "action_text",
      "value": "@global.review_action_text"
    },
    {
      "name": "badge_text",
      "value": "@global.review_badge_text"
    },
    {
      "type": "end_template"
    },
    {
      "type": "plh_get_up_next",
      "name": "up_next"
    },
    {
      "type": "text",
      "value": "up_next value:"
    },
    {
      "type": "text",
      "value": "@calc(JSON.stringify(@local.up_next || {}))"
    },
    {
      "type": "begin_display_group",
      "parameter_list": "style: column",
      "condition": "!@local.hp_id"
    },
    {
      "name": "start_at_id",
      "value": "_start_at_id"
    },
    {
      "name": "target_template",
      "value": "not used",
      "exclude_from_translation": true
    },
    {
      "type": "begin_template",
      "value": "header_button",
      "condition": "!!@local.up_next.module_id",
      "exclude_from_translation": true
    },
    {
      "name": "title",
      "value": "@local.up_next.module_title",
      "exclude_from_translation": true
    },
    {
      "name": "course_id",
      "value": "@local.up_next.course_id",
      "exclude_from_translation": true
    },
    {
      "name": "subtitle",
      "value": "@local.up_next.course_title",
      "exclude_from_translation": true
    },
    {
      "name": "template",
      "value": "stack_module_@local.up_next.module_id@local.start_at_id",
      "exclude_from_translation": true
    },
    {
      "name": "pop_up",
      "value": true
    },
    {
      "name": "action_text",
      "value": "@global.course_action_text",
      "exclude_from_translation": true
    },
    {
      "name": "badge_text",
      "value": "@global.course_badge_text",
      "exclude_from_translation": true
    },
    {
      "name": "module_id",
      "value": "@local.up_next.module_id",
      "exclude_from_translation": true
    },
    {
      "type": "end_template",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "all_completed",
      "parameter_list": "style: column;",
      "condition": "!!@local.up_next.check_complete && !@local.up_next.module_id",
      "exclude_from_translation": true
    },
    {
      "type": "title",
      "value": "@global.all_complete_title",
      "condition": "!!@global.all_complete_title",
      "exclude_from_translation": true,
      "style_list": "margin-top: -8px;"
    },
    {
      "type": "text",
      "value": "@global.all_complete_text",
      "condition": "!!@global.all_complete_text",
      "exclude_from_translation": true,
      "style_list": "margin-top: -6px;\nmargin-bottom: -8px;"
    },
    {
      "type": "begin_display_group",
      "parameter_list": "style: column",
      "exclude_from_translation": true,
      "style_list": "background-color: #669F4B40;"
    },
    {
      "type": "text",
      "exclude_from_translation": true
    },
    {
      "type": "image",
      "value": "@global.all_complete_image",
      "exclude_from_translation": true,
      "style_list": "width: 145px;\nheight: 110px;"
    },
    {
      "type": "text"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_template",
      "value": "debug_complete_course"
    },
    {
      "type": "end_template"
    }
  ]
}