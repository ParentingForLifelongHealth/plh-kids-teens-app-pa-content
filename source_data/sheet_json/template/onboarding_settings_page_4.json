{
  "flow_type": "template",
  "flow_name": "onboarding_settings_page_4",
  "status": "released",
  "rows": [
    {
      "name": "facilitator_id",
      "value": "@fields.facilitator_id"
    },
    {
      "name": "facilitator_data",
      "value": "characters.@local.facilitator_id"
    },
    {
      "name": "facilitator_row",
      "value": "@data.@local.facilitator_data"
    },
    {
      "name": "speaker_name",
      "value": "@local.facilitator_row.name"
    },
    {
      "name": "speaker_image_asset",
      "value": "@local.facilitator_row.image_asset"
    },
    {
      "name": "speaker_position",
      "value": "left",
      "exclude_from_translation": true
    },
    {
      "name": "variant",
      "value": "gray",
      "exclude_from_translation": true
    },
    {
      "type": "text_bubble",
      "name": "text_bubble",
      "value": "@global.facilitator_message_user_age",
      "parameter_list": "speaker_image_asset: @local.speaker_image_asset;\nspeaker_name: @local.speaker_name;\nspeaker_position: @local.speaker_position;\nvariant: @local.variant;",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "question_user_age",
      "value": "@global.question_user_age",
      "parameter_list": "style: emphasised;",
      "exclude_from_translation": true
    },
    {
      "type": "text_box",
      "name": "user_age_input",
      "value": "@fields.user_age",
      "parameter_list": "placeholder: @global.placeholder_user_age;\nnumber_input: true;",
      "condition": "!!@fields.user_age",
      "exclude_from_translation": true
    },
    {
      "type": "text_box",
      "name": "user_age_input",
      "parameter_list": "placeholder: @global.placeholder_user_age;\nnumber_input: true;",
      "condition": "!@fields.user_age",
      "exclude_from_translation": true
    },
    {
      "name": "valid_user_age_input",
      "value": "@calc((/^\\d+$/.test(@local.user_age_input) && @local.user_age_input>= 18 && @local.user_age_input<= 99) || @local.user_age_input == '' || !@local.user_age_input)",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "warning_user_age_input",
      "value": "@global.warning_user_age_input",
      "condition": "!@local.valid_user_age_input",
      "style_list": "color: #FF0000;\nfont-size: 14px",
      "exclude_from_translation": true
    },
    {
      "name": "completed_enabled",
      "value": "@local.valid_user_age_input  && !!@local.user_age_input ",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.continue",
      "action_list": "click | set_field: user_age: @local.user_age_input;\nclick | emit: completed;",
      "parameter_list": "style: navigation;\ndisabled: !@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}