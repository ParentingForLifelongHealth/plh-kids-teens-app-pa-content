    {
      "type": "data_items",
      "name": "get_last_in_progress",
      "value": "@data.module_tasks",
      "action_list": "data_changed | set_local : module_id : @items[0]?.id;\ndata_changed | set_local : module_title : @items[0]?.title;\ndata_changed | set_local : course_id :@items[0]?.tag_course;\ndata_changed | set_local : has_in_progress : @items.length;",
      "parameter_list": "filter: !!@item.last_accessed_ts&& !@item.completed_ts && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship)) ;\nsort: last_accessed_ts;\nreverse;",
      "exclude_from_translation": true,
      "comment": "(!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag))"
    },
    {
      "type": "data_items",
      "name": "get_last_completed",
      "value": "@data.module_tasks",
      "action_list": "data_changed | set_local : course_id: @items[0]?.tag_course;\ndata_changed | set_local : has_last_completed: @items.length;",
      "parameter_list": "filter: !!@item.completed_ts && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship)) ;\nsort: completed_ts;\nreverse;",
      "condition": "@local.has_in_progress == 0",
      "exclude_from_translation": true,
      "comment": "only run if none currently in progress"
    },
    {
      "exclude_from_translation": true
    },
    {
      "type": "data_items",
      "name": "get_next_in_module",
      "value": "@data.module_tasks",
      "action_list": "data_changed | set_local : module_id : @items[0]?.id;\ndata_changed | set_local : module_title : @items[0]?.title;\ndata_changed | set_local : has_next_module : @items.length;",
      "parameter_list": "filter: !@item.completed_ts && (@item.tag_course == @local.course_id) && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship)) ;\nsort: number;\nlimit: 1;",
      "condition": "@local.has_last_completed > 0",
      "exclude_from_translation": true,
      "comment": "only run if we have a last completed"
    },
    {
      "type": "data_items",
      "name": "get_first_item",
      "value": "@data.module_tasks",
      "action_list": "data_changed | set_local : module_id : @items[0]?.id;\ndata_changed | set_local : module_title : @items[0]?.title;\ndata_changed | set_local : course_id :@items[0]?.tag_course;\ndata_changed | set_local : stop_flick : @items.length;",
      "parameter_list": "filter: !@item.completed_ts && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship)) ;\nsort: number;\nlimit: 1;",
      "condition": "(@local.has_in_progress == 0) && ((@local.has_last_completed == 0) || (@local.has_next_module == 0))",
      "exclude_from_translation": true,
      "comment": "default to next in list if not found "
