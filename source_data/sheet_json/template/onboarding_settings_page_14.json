{
  "flow_type": "template",
  "flow_name": "onboarding_settings_page_14",
  "status": "released",
  "rows": [
    {
      "name": "facilitator_id",
      "value": "@fields.facilitator_id"
    },
    {
      "name": "facilitator_data",
      "value": "characters.@local.facilitator_id"
    },
    {
      "name": "facilitator_row",
      "value": "@data.@local.facilitator_data"
    },
    {
      "name": "speaker_name",
      "value": "@local.facilitator_row.name"
    },
    {
      "name": "speaker_image_asset",
      "value": "@local.facilitator_row.image_asset"
    },
    {
      "name": "speaker_position",
      "value": "left"
    },
    {
      "name": "variant",
      "value": "gray"
    },
    {
      "type": "text",
      "value": "Starting your setup...",
      "parameter_list": "style: emphasised;"
    },
    {
      "type": "begin_items",
      "name": "loading_bars",
      "value": "onboarding_progress_bars",
      "condition": false,
      "comments": "It would be nice to get this working from a datalist"
    },
    {
      "type": "text",
      "value": "@item.text"
    },
    {
      "type": "plh_progress_bar",
      "parameter_list": "title: @item.text;\nduration: @item.timespan;\nauto_play: true;\ncolor: @item.colour"
    },
    {
      "type": "end_items"
    },
    {
      "parameter_list": "@data.characters.f3_hija_7.name"
    },
    {
      "type": "plh_progress_bar",
      "name": "bar_1",
      "parameter_list": "title: @data.onboarding_progress_bars.id_1.text;\nduration: @data.onboarding_progress_bars.id_1.timespan;\nauto_play: true;\ncolor: @data.onboarding_progress_bars.id_1.colour"
    },
    {
      "type": "plh_progress_bar",
      "name": "bar_2",
      "parameter_list": "title: @data.onboarding_progress_bars.id_2.text;\nduration: @data.onboarding_progress_bars.id_2.timespan;\nauto_play: @local.bar_1 == 100;\ncolor: @data.onboarding_progress_bars.id_2.colour;"
    },
    {
      "type": "plh_progress_bar",
      "name": "bar_3",
      "value": "@calc((@local.completed_count / @local.total_count) * 100)",
      "parameter_list": "title: @data.onboarding_progress_bars.id_3.text;\nauto_play: @local.bar_2 == 100;\ncolor: @data.onboarding_progress_bars.id_3.colour;"
    },
    {
      "name": "completed_count "
    },
    {
      "name": "total_count"
    },
    {
      "type": "plh_progress_bar",
      "name": "assets_bar",
      "parameter_list": "auto_play: @local.bar_3 == 100;"
    },
    {
      "type": "data_items",
      "value": "_asset_packs",
      "action_list": "data_changed | set_local : total_count: @items.length;"
    },
    {
      "type": "data_items",
      "value": "_asset_packs",
      "action_list": "data_changed | set_local : completed_count: @items.length;",
      "parameter_list": "filter: (@item.status == \"completed\");"
    },
    {
      "type": "begin_data_items"
    },
    {
      "type": "text",
      "value": "id: @item.id,\nname: @item.name,\ndownload_status: @item.download_status"
    },
    {
      "type": "end_data_items"
    }
  ]
}