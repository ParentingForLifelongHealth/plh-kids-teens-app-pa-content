{
  "flow_type": "template",
  "flow_subtype": "proximal_outcomes",
  "flow_name": "set_domain",
  "status": "released",
  "rows": [
    {
      "name": "speaker_position",
      "value": "left",
      "exclude_from_translation": true
    },
    {
      "name": "variant",
      "value": "gray",
      "exclude_from_translation": true
    },
    {
      "name": "facilitator_id",
      "value": "@fields.facilitator_id",
      "exclude_from_translation": true
    },
    {
      "name": "facilitator_data",
      "value": "characters.@local.facilitator_id",
      "exclude_from_translation": true
    },
    {
      "name": "facilitator_row",
      "value": "@data.@local.facilitator_data",
      "exclude_from_translation": true
    },
    {
      "type": "text_bubble",
      "name": "text_bubble",
      "value": "@global.set_domain_question",
      "parameter_list": "speaker_position: @local.speaker_position;\nvariant: @local.variant;",
      "exclude_from_translation": true
    },
    {
      "type": "radio_list",
      "name": "domain_select",
      "value": "@fields.selected_domain",
      "action_list": "click | ",
      "parameter_list": "answer_list: @data.domains;\noptions_key: id;\noptions_value: title;\nvariant: boxed;",
      "exclude_from_translation": true
    },
    {
      "name": "completed_enabled",
      "value": "!!@local.domain_select",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "dg_footer",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "round_button",
      "name": "button_back",
      "action_list": "click | emit: uncompleted",
      "parameter_list": "icon_src: arrow-back;\nvariant: no-background;"
    },
    {
      "type": "button",
      "name": "button_completed",
      "value": "@global.continue_onb",
      "action_list": "click | set_field: selected_domain: @local.domain_select;\nclick | emit: completed;",
      "parameter_list": "style: navigation;\ndisabled: !@local.completed_enabled",
      "style_list": "flex: 1"
    },
    {
      "type": "end_display_group"
    }
  ]
}