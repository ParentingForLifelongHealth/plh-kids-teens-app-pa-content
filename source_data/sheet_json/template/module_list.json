{
  "flow_type": "template",
  "flow_name": "module_list",
  "status": "released",
  "rows": [
    {
      "name": "current_module_id"
    },
    {
      "name": "has_completed",
      "value": 0
    },
    {
      "name": "has_core_course",
      "value": 0
    },
    {
      "name": "courses_not_done"
    },
    {
      "type": "data_items",
      "value": "@data.courses",
      "action_list": "data_changed | set_local : has_core_course: @items.length;",
      "parameter_list": "filter: @item.core && !@item.completed && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship))"
    },
    {
      "type": "begin_display_group",
      "name": "core_title",
      "parameter_list": "style: column",
      "condition": "@local.has_core_course > 0"
    },
    {
      "type": "title",
      "value": "@global.unlock_course_title",
      "condition": "!!@global.unlock_course_title",
      "style_list": "margin-top: -8px;"
    },
    {
      "type": "text",
      "value": "@global.unlock_course_text",
      "condition": "!!@global.unlock_course_text",
      "style_list": "margin-top: -6px;\nmargin-bottom: -8px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_display_group",
      "name": "unlocked_title",
      "parameter_list": "style: column",
      "condition": "@local.has_core_course == 0"
    },
    {
      "type": "title",
      "value": "@global.all_unlock_course_title",
      "condition": "!!@global.all_unlock_course_title",
      "style_list": "margin-top: -8px;"
    },
    {
      "type": "text",
      "value": "@global.all_unlock_course_text",
      "condition": "!!@global.all_unlock_course_text",
      "style_list": "margin-top: -6px;\nmargin-bottom: -8px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_data_items",
      "name": "core_courses",
      "value": "@data.courses",
      "parameter_list": "filter: @item.core && !@item.completed && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship));",
      "condition": "@local.has_core_course > 0",
      "exclude_from_translation": true,
      "comments": "filter: @item.core && !@item.completed;"
    },
    {
      "type": "begin_template",
      "value": "module_group",
      "exclude_from_translation": true
    },
    {
      "name": "course",
      "value": "@item.id",
      "exclude_from_translation": true
    },
    {
      "name": "course_title",
      "value": "@item.title"
    },
    {
      "name": "course_image",
      "value": "@item.image_asset"
    },
    {
      "type": "end_template",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "upcoming_title",
      "parameter_list": "style: column",
      "condition": "@local.has_core_course > 0"
    },
    {
      "type": "title",
      "value": "@global.lock_course_title",
      "condition": "!!@global.lock_course_title",
      "style_list": "margin-top: -8px;"
    },
    {
      "type": "text",
      "value": "@global.lock_course_text",
      "condition": "!!@global.lock_course_text",
      "style_list": "margin-top: -6px;\nmargin-bottom: -8px;"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_data_items",
      "name": "other_courses",
      "value": "@data.courses",
      "parameter_list": "filter: !@item.core && !@item.completed && (!@item.tag_list || @item.tag_list.includes(@fields.child_age_tag)) && (!@item.age_list || @item.age_list.includes(@fields.child_age)) && (!@item.child_gender_list || @item.child_gender_list.includes(@fields.child_gender)) && (!@item.caregiver_relationship_list || @item.caregiver_relationship_list.includes(@fields.user_relationship));",
      "exclude_from_translation": true,
      "comments": "filter: !@item.core && !@item.completed;"
    },
    {
      "type": "begin_template",
      "value": "module_group",
      "exclude_from_translation": true,
      "comments": "filter: !@item.core && [@local.courses_not_done].includes(@item.id)"
    },
    {
      "name": "course",
      "value": "@item.id",
      "exclude_from_translation": true
    },
    {
      "name": "course_title",
      "value": "@item.title"
    },
    {
      "name": "course_image",
      "value": "@item.image_asset"
    },
    {
      "name": "all_locked",
      "value": "(@local.has_core_course > 0)"
    },
    {
      "type": "end_template",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "name": "completed_title",
      "parameter_list": "style: column",
      "condition": "@local.has_core_course == 0",
      "comments": "must have completed something"
    },
    {
      "type": "title",
      "value": "@global.complete_course_title"
    },
    {
      "type": "text",
      "value": "@global.complete_course_text"
    },
    {
      "type": "end_display_group"
    },
    {
      "type": "begin_data_items",
      "name": "completed_courses",
      "value": "@data.courses",
      "parameter_list": "filter: !!@item.completed",
      "condition": "@local.has_core_course == 0",
      "exclude_from_translation": true,
      "comments": "filter: !([@local.courses_list].includes(@item.id))"
    },
    {
      "comments": "filter: !([@local.courses_not_done].includes(@item.id))"
    },
    {
      "type": "begin_template",
      "value": "module_group",
      "exclude_from_translation": true
    },
    {
      "name": "course",
      "value": "@item.id",
      "exclude_from_translation": true
    },
    {
      "name": "course_title",
      "value": "@item.title"
    },
    {
      "name": "course_image",
      "value": "@item.image_asset"
    },
    {
      "name": "completed_course",
      "value": true
    },
    {
      "type": "end_template",
      "exclude_from_translation": true
    },
    {
      "type": "end_data_items",
      "exclude_from_translation": true
    }
  ]
}