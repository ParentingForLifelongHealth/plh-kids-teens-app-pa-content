      "value": "tag_list: @item.tag_list"
    },
    {
      "type": "text",
      "value": "@calc(@item.tag_list.includes(@fields.child_age_tag))",
      "condition": false
    },
    {
      "type": "text",
      "value": "age_list: @item.age_list"
    },
    {
      "type": "text",
      "value": "@calc(@item.age_list.includes(@fields.child_age))",
      "condition": false
